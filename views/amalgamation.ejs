<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light"><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Generate Amalgamation — lexbor</title>
<%- include('header.ejs') %>
    <style>
        .modules-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 5px 20px;
            margin: 10px 0;
        }
        .modules-grid label {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-weight: normal;
            width: auto;
            cursor: pointer;
        }
        .modules-grid input[type="checkbox"] {
            width: auto;
        }
        .api-section {
            background: #f5f5f5;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 15px;
            margin-top: 20px;
            font-size: 0.9em;
        }
        .api-section .desc {
            margin: 12px 0 5px;
            font-size: 0.85em;
            color: #555;
        }
        .api-section .desc:first-of-type {
            margin-top: 5px;
        }
        .api-section .cmd {
            position: relative;
            background: #eee;
            border-radius: 3px;
            padding: 8px 65px 8px 10px;
            margin-bottom: 8px;
        }
        .api-section .cmd code {
            font-family: monospace;
            word-break: break-all;
        }
        .api-section .cmd .copy-btn {
            position: absolute;
            top: 6px;
            right: 6px;
            padding: 3px 8px;
            font-size: 0.8em;
        }
        .api-section .styled-table {
            margin-top: 12px;
            font-size: 0.9em;
        }
        .api-section .styled-table code {
            font-family: monospace;
            background: #e8e8e8;
            padding: 1px 4px;
            border-radius: 2px;
            white-space: nowrap;
        }
        .inline-fields {
            display: flex;
            gap: 15px;
            align-items: flex-end;
        }
        .inline-fields .form-group {
            margin-bottom: 0;
        }
        .inline-fields input[type="text"] {
            width: 250px;
        }
        .inline-fields select {
            padding: 8px;
        }
        .btn-group {
            margin-top: 15px;
            display: flex;
            gap: 8px;
            align-items: center;
        }
        #loading-modules {
            color: #888;
            font-style: italic;
        }
    </style>
</head>
<body>
<%- include('body.ejs') %>
                    <h1>Generate Amalgamation</h1>
                    <p style="margin-bottom: 20px;">Select modules to include in the amalgamation build. If none are selected, all modules will be included.</p>

                    <% if (error) { %>
                        <div style="color: red; margin-bottom: 15px; padding: 10px; border: 1px solid red; border-radius: 3px;">
                            <%= error %>
                        </div>
                    <% } %>

                    <div class="form-group">
                        <label><strong>Version:</strong></label>
                        <select id="version-select" style="padding: 8px; width: 200px;">
                            <% versions.forEach(v => { %>
                                <option value="<%= v %>"><%= v %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label><strong>Modules:</strong></label>
                        <span id="loading-modules" style="display: none;">Loading modules...</span>
                        <div id="modules-container" class="modules-grid">
                            <% modules.forEach(mod => { %>
                                <label>
                                    <input type="checkbox" name="modules" value="<%= mod %>"> <%= mod %>
                                </label>
                            <% }); %>
                        </div>
                    </div>

                    <div class="btn-group" style="margin-top: 5px; margin-bottom: 15px;">
                        <button type="button" onclick="toggleAll(true)">Select All</button>
                        <button type="button" onclick="toggleAll(false)">Deselect All</button>
                    </div>

                    <div class="inline-fields">
                        <div class="form-group">
                            <label><strong>Filename:</strong></label>
                            <input type="text" id="filename-input" placeholder="leave empty for auto">
                        </div>
                        <div class="form-group">
                            <label><strong>Extension:</strong></label>
                            <input type="text" id="ext-input" value="h" style="width: 80px;">
                        </div>
                    </div>

                    <div class="btn-group">
                        <button type="button" class="btn-success" onclick="generateAmalgamation()">Generate &amp; Download</button>
                    </div>

                    <div class="api-section">
                        <strong>API Usage</strong>

                        <p class="desc">Download amalgamation file (<code>-O</code> save to file, <code>-J</code> use server filename):</p>
                        <div class="cmd">
                            <code id="curl-download"></code>
                            <button type="button" class="copy-btn" onclick="copyCurl('curl-download')">Copy</button>
                        </div>

                        <p class="desc">List available modules for a version:</p>
                        <div class="cmd">
                            <code id="curl-modules"></code>
                            <button type="button" class="copy-btn" onclick="copyCurl('curl-modules')">Copy</button>
                        </div>

                        <table class="styled-table">
                            <thead>
                                <tr><th>Parameter</th><th>Description</th></tr>
                            </thead>
                            <tbody>
                                <tr><td><code>version</code></td><td><code>latest</code> — most recent stable release<br><code>master</code> — development branch (latest commit)<br>or a release tag, e.g. <code>v2.7.0</code></td></tr>
                                <tr><td><code>modules</code></td><td>Comma-separated list of specific modules (e.g. <code>core,dom,html</code>)<br><code>lexbor</code> — include all available modules<br>or omit the parameter entirely to include all modules</td></tr>
                                <tr><td><code>ext</code></td><td>File extension, default <code>h</code> (alphanumeric, <code>_</code>, <code>-</code>)</td></tr>
                                <tr><td><code>filename</code></td><td>Custom output filename (optional, alphanumeric, <code>_</code>, <code>-</code>)</td></tr>
                            </tbody>
                        </table>
                    </div>

<%- include('body-end.ejs') %>
    <script>
        const versionSelect = document.getElementById('version-select');
        const modulesContainer = document.getElementById('modules-container');
        const loadingModules = document.getElementById('loading-modules');
        const filenameInput = document.getElementById('filename-input');
        const extInput = document.getElementById('ext-input');
        const curlDownload = document.getElementById('curl-download');
        const curlModules = document.getElementById('curl-modules');

        function getSelectedModules() {
            return Array.from(document.querySelectorAll('input[name="modules"]:checked'))
                .map(cb => cb.value);
        }

        function getAllModules() {
            return Array.from(document.querySelectorAll('input[name="modules"]'))
                .map(cb => cb.value);
        }

        function isNoneOrAllSelected() {
            const all = getAllModules();
            const selected = getSelectedModules();
            return selected.length === 0 || (all.length > 0 && selected.length === all.length);
        }

        function getAutoFilename() {
            const selected = getSelectedModules();
            if (isNoneOrAllSelected()) return 'lexbor';
            return [...selected].sort().join('_');
        }

        function updateFilenamePreview() {
            const userInput = filenameInput.value.replace(/[^a-zA-Z0-9_-]/g, '');
            if (!userInput) {
                filenameInput.placeholder = getAutoFilename() || 'leave empty for auto';
            }
        }

        function toggleAll(checked) {
            document.querySelectorAll('input[name="modules"]').forEach(cb => cb.checked = checked);
            updateFilenamePreview();
            updateCurl();
        }

        function buildDownloadUrl(forCurl) {
            const version = versionSelect.value;
            const modules = getSelectedModules();
            const ext = extInput.value.replace(/[^a-zA-Z0-9_-]/g, '') || 'h';
            const filename = filenameInput.value.replace(/[^a-zA-Z0-9_-]/g, '');

            let url = `/api/amalgamation?version=${encodeURIComponent(version)}`;

            if (forCurl && isNoneOrAllSelected()) {
                url += '&modules=lexbor';
            } else if (modules.length > 0) {
                url += `&modules=${encodeURIComponent(modules.join(','))}`;
            }

            url += `&ext=${encodeURIComponent(ext)}`;

            if (filename) {
                url += `&filename=${encodeURIComponent(filename)}`;
            }

            return url;
        }

        function updateCurl() {
            const version = versionSelect.value;
            const origin = window.location.origin;

            curlDownload.textContent = `curl -OJ "${origin}${buildDownloadUrl(true)}"`;
            curlModules.textContent = `curl "${origin}/api/amalgamation/modules?version=${encodeURIComponent(version)}"`;
        }

        function copyCurl(elementId) {
            const el = document.getElementById(elementId);
            navigator.clipboard.writeText(el.textContent).then(() => {
                const btn = el.parentElement.querySelector('.copy-btn');
                const orig = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(() => { btn.textContent = orig; }, 1500);
            });
        }

        function generateAmalgamation() {
            window.location = buildDownloadUrl(false);
        }

        async function loadModules(version) {
            loadingModules.style.display = 'inline';
            modulesContainer.style.opacity = '0.5';

            try {
                const resp = await fetch(`/api/amalgamation/modules?version=${encodeURIComponent(version)}`);
                const data = await resp.json();

                if (!resp.ok) {
                    console.error('Error loading modules:', data.error);
                    return;
                }

                modulesContainer.innerHTML = data.modules.map(mod =>
                    `<label><input type="checkbox" name="modules" value="${mod}" onchange="updateFilenamePreview(); updateCurl()"> ${mod}</label>`
                ).join('');
            } catch (err) {
                console.error('Failed to load modules:', err);
            } finally {
                loadingModules.style.display = 'none';
                modulesContainer.style.opacity = '1';
            }

            updateCurl();
        }

        // Event listeners
        versionSelect.addEventListener('change', () => {
            loadModules(versionSelect.value);
        });

        filenameInput.addEventListener('input', () => { updateFilenamePreview(); updateCurl(); });
        extInput.addEventListener('input', updateCurl);

        // Add onchange to initial checkboxes
        document.querySelectorAll('input[name="modules"]').forEach(cb => {
            cb.addEventListener('change', () => { updateFilenamePreview(); updateCurl(); });
        });

        // Initialize curl on page load
        updateFilenamePreview();
        updateCurl();
    </script>
<%- include('footer.ejs') %>
</body>
</html>
